# Public URL of your relay — used in QR code during pairing.
# Must be reachable from both your phone and your agent machines.
# Example: https://relay.example.com  or  http://192.168.1.10:8080
RELAY_URL=http://localhost:8080

# Secret used to sign JWTs. Generate with: openssl rand -hex 32
# REQUIRED in production — change this before deploying.
RELAY_JWT_SECRET=change-me-at-least-32-chars-long!!

# Admin password for the web UI / API login.
# Set this to skip the interactive first-run prompt (useful for Docker).
# RELAY_ADMIN_PASSWORD=your-admin-password

# SQLite database file path (inside the container volume).
RELAY_DB=/app/data/relay.db

# Relay listen address.
RELAY_ADDR=:8080
